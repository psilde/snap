<Window x:Class="Snap.Views.OverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        KeyDown="OverlayWindow_KeyDown">
    <Canvas x:Name="RootCanvas">
        <Image x:Name="DimmedBackdrop" Stretch="None"/>
        <Rectangle x:Name="SelectionBorder" Stroke="White" StrokeThickness="1" Visibility="Collapsed" IsHitTestVisible="False"/>
        <Image x:Name="RevealImage" Stretch="None" Visibility="Collapsed" IsHitTestVisible="False"/>
        <TextBlock x:Name="SizeLabel" Foreground="White" Background="#AA000000" Padding="4,2" Visibility="Collapsed" IsHitTestVisible="False"/>
    </Canvas>
</Window>
