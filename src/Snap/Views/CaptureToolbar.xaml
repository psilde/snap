<UserControl x:Class="Snap.Views.CaptureToolbar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border Background="#EE222222" CornerRadius="4" Padding="4">
        <StackPanel Orientation="Horizontal">
            <Button x:Name="BlurButton" Content="Blur" Margin="2" Padding="8,4" Click="BlurButton_Click"/>
            <Button x:Name="CopyButton" Content="Copy" Margin="2" Padding="8,4" Click="CopyButton_Click"/>
            <Button x:Name="SaveButton" Content="Save" Margin="2" Padding="8,4" Click="SaveButton_Click"/>
            <Button x:Name="CancelButton" Content="✕" Margin="2" Padding="8,4" Click="CancelButton_Click"/>
        </StackPanel>
    </Border>
</UserControl>
